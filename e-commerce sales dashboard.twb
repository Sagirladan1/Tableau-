      <aliases enabled='yes' />
      <column caption='% Difference' datatype='real' name='[Calculation_1038642682264649729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_40532413006876690])-SUM([YTD Sales (copy)_1038642682264449024]))/SUM([YTD Sales (copy)_1038642682264449024])' />
      </column>
      <column caption='Sales Margin' datatype='string' name='[Calculation_1038642682266259458]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Calculation_40532413006876690])-SUM([YTD Sales (copy)_1038642682264449024])&lt;0 THEN &apos;Less Than PY&apos;&#13;&#10;ELSEIF SUM([Calculation_40532413006876690])-SUM([YTD Sales (copy)_1038642682264449024])&gt;0 THEN &apos;Greater Than PY&apos;&#13;&#10;ELSEIF ISNULL(SUM([YTD Sales (copy)_1038642682264449024])) THEN &apos;No sales in PY&apos;&#13;&#10;END' />
      </column>
      <column caption='Positive % diff' datatype='string' name='[Calculation_1038642682268221443]' role='measure' type='nominal'>
        <calculation class='tableau' formula='if [Calculation_1038642682264649729]&gt;0 THEN &apos;˄&apos;  END' />
      </column>
      <column caption='No sales' datatype='string' name='[Calculation_1038642682269306885]' role='measure' type='nominal'>
        <calculation class='tableau' formula='if [Calculation_1038642682266259458]= &apos;No sales in PY&apos; THEN &apos;No sales in PY&apos; END' />
      </column>
      <column caption='YTD Sales LOD' datatype='real' name='[Calculation_40532412382605312]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : SUM(IF YEAR([Order Date])= {MAX(YEAR([Order Date]))} THEN [Sales] END )}' />
      </column>
      <column caption='YOY Sales %' datatype='real' name='[Calculation_40532412385689602]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_40532412382605312] - [YTD Sales LOD (copy)_40532412385308673])/ [YTD Sales LOD (copy)_40532412385308673]' />
      </column>
      <column caption='YOY Sales Margin' datatype='string' name='[Calculation_40532412788158467]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_40532412385689602]&gt;0 THEN &apos;˄&apos; ELSEIF [Calculation_40532412385689602]&lt;0 THEN &apos;˅&apos; END' />
      </column>
      <column caption='YTD Sales' datatype='real' name='[Calculation_40532413006876690]' role='measure' type='quantitative'>
